{
  "manifest_version": 3,
  "name": "d2jsp Post Text Color Remover",
  "version": "1.0",
  "description": "Removes colored text from posts by Taurean on forums.d2jsp.",
  "permissions": ["scripting"],
  "content_scripts": [
    {
      "matches": ["https://forums.d2jsp.org/topic.php*"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
